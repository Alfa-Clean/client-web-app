{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "client-mini-app",
  "compatibility_date": "2026-05-13",
  "compatibility_flags": ["nodejs_compat"],
  "observability": { "enabled": true },
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application",
    "binding": "ASSETS"
  },
  "main": "./worker.ts"
}
